#!/usr/bin/env bash
set -euo pipefail

session=main
workdir=/home/agent/workspace

if [[ -z ${TMUX:-} && ( ! -t 0 || ! -t 1 ) ]]; then
  printf 'tm: an interactive terminal is required outside tmux\n' >&2
  exit 1
fi

if [[ ! -d $workdir ]]; then
  printf 'tm: required workspace is unavailable: %s\n' "$workdir" >&2
  exit 1
fi

# Preserve Ghostty's terminal identity when its terminfo is installed, and
# degrade only when tmux could not otherwise understand it.
if [[ ${TERM:-} == xterm-ghostty ]] &&
  ! infocmp -x xterm-ghostty >/dev/null 2>&1; then
  export TERM=xterm-256color
fi

if [[ -n ${TMUX:-} ]]; then
  current_session=$(tmux display-message -p '#S')
  if [[ $current_session == "$session" ]]; then
    exit 0
  fi
  if ! tmux has-session -t "=$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -c "$workdir" 2>/dev/null ||
      tmux has-session -t "=$session"
  fi
  exec tmux switch-client -t "=$session"
fi

if ! tmux has-session -t "=$session" 2>/dev/null; then
  tmux new-session -d -s "$session" -c "$workdir" 2>/dev/null ||
    tmux has-session -t "=$session"
fi
exec tmux attach-session -t "=$session"
