# Copy to hermes-box.conf to override defaults.
HERMES_BOX_MACHINE_NAME=hermes-box
HERMES_BOX_BUILDER_NAME=hermes-builder
HERMES_BOX_SSH_PORT=2222
HERMES_BOX_CPUS=4
HERMES_BOX_MEMORY_MIB=8192
HERMES_BOX_STORAGE_GB=15
HERMES_BOX_OVERLAY_GB=6
HERMES_BOX_NETWORK_MODE=none

# Optional: pin the Hermes source install to a full Git commit.
# HERMES_BOX_HERMES_COMMIT=

# Optional: store images, backups, and runtime state outside the repository.
# HERMES_BOX_DATA_DIR=
