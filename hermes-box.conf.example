# Copy to hermes-box.conf to override defaults. Unknown HERMES_BOX_* keys are
# rejected so configuration typos cannot silently change behavior.
HERMES_BOX_MACHINE_NAME=hermes-box
HERMES_BOX_BUILDER_NAME=hermes-builder
HERMES_BOX_SSH_PORT=2222
HERMES_BOX_CPUS=4
HERMES_BOX_MEMORY_MIB=8192
HERMES_BOX_STORAGE_GB=15
HERMES_BOX_OVERLAY_GB=6
HERMES_BOX_NETWORK_MODE=full

# Optional: use one stable external private key for this box. Keep it outside
# backup archives (for example in 1Password) and supply the same key on restore.
# HERMES_BOX_SSH_KEY=/secure/path/hermes-box-ed25519

# Optional native Executor gateway pulled from a digest-pinned OCI image and
# exposed on host loopback only.
HERMES_BOX_EXECUTOR_ENABLED=false
HERMES_BOX_EXECUTOR_PORT=4788
HERMES_BOX_EXECUTOR_IMAGE=ghcr.io/rhyssullivan/executor-selfhost:v1.5.16@sha256:5d763c718b6567d56e0168d3c205065a37355da1468290f2030f7f6c792f02b6

# The gated-approval source patch is reviewed against this exact Hermes 0.16.0
# revision. Changing it intentionally fails provisioning until the patch and
# its upstream anchors are reviewed for the new revision.
HERMES_BOX_HERMES_COMMIT=81eaedd0f5c471c7ee748990066135a684f3c962

# Optional: store images, backups, and runtime state outside the repository.
# HERMES_BOX_DATA_DIR=
