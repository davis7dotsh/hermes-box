#!/usr/bin/env bash
set -euo pipefail

source_path=${BASH_SOURCE[0]}
while [[ -L $source_path ]]; do
  source_dir=$(cd "$(dirname "$source_path")" && pwd)
  source_path=$(readlink "$source_path")
  [[ $source_path == /* ]] || source_path=$source_dir/$source_path
done
script_dir=$(cd "$(dirname "$source_path")" && pwd)
project_root=$(cd "$script_dir/.." && pwd)
state_dir=$project_root/state
binary=$state_dir/hermes-box-go
temporary_binary=$binary.tmp-$$

export HERMES_BOX_PROJECT_ROOT=$project_root

needs_build=false
if [[ ! -x $binary ]]; then
  needs_build=true
elif find \
  "$project_root/cmd" \
  "$project_root/internal" \
  "$project_root/go.mod" \
  -type f -newer "$binary" -print -quit |
  grep -q .; then
  needs_build=true
fi

if [[ $needs_build == true ]]; then
  install -d -m 0700 "$state_dir"
  trap 'rm -f "$temporary_binary"' EXIT
  go build -o "$temporary_binary" "$project_root/cmd/hermes-box"
  chmod 0700 "$temporary_binary"
  mv -f "$temporary_binary" "$binary"
  trap - EXIT
fi

exec "$binary" "$@"
